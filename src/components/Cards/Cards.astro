---
import Card1 from "./Card1.astro";
import Card2 from "./Card2.astro";
import Card3 from "./Card3.astro";
import Card4 from "./Card4.astro";
import Card5 from "./Card5.astro";
---

<div class="mx-auto" id="proyectos">
    <h2 class="text-center mb-6">Mis Proyectos</h2>
    <div class="w-full px-4 lg:px-8 py-2">
        <div class="grid grid-cols-1 lg:grid-cols-6 gap-6 px-4 lg:px-8">
            <div class="flex lg:col-start-2 lg:col-span-2"><Card4 /></div>
            <div class="flex lg:col-start-4 lg:col-span-2"><Card5 /></div>
            <div class="flex lg:col-span-2"><Card1 /></div>
            <div class="flex lg:col-span-2"><Card2 /></div>
            <div class="flex lg:col-span-2"><Card3 /></div>
        </div>
    </div>
</div>
