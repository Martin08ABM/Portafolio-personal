---
interface Props {
  title: string;
  image: string;
  imageAlt: string;
  description: string;
  techs: string[];
  githubUrl: string;
  liveUrl?: string;
}

const { title, image, imageAlt, description, techs, githubUrl, liveUrl } = Astro.props;
---

<section class="border border-[#ff4f6a] px-4 py-3 w-full h-full hover:border-pink-500 transition-all ease-in-out duration-300 hover:scale-105 flex flex-col">
  <h3 class="text-neutral-200 text-lg font-bold mb-3">{title}</h3>
  {liveUrl ? (
    <a href={liveUrl} target="_blank" rel="noopener noreferrer">
      <img src={image} alt={imageAlt} class="border border-neutral-600 mb-3 w-full h-44 object-cover" />
    </a>
  ) : (
    <img src={image} alt={imageAlt} class="border border-neutral-600 mb-3 w-full h-44 object-cover" />
  )}
  <p class="text-xs leading-relaxed">{description}</p>
  <div class="mt-3">
    <span class="text-xs text-neutral-500 uppercase tracking-widest">Stack</span>
    <ul class="flex flex-row flex-wrap gap-1.5 mt-2">
      {techs.map((tech) => (
        <li class="px-2 py-0.5 border border-neutral-700 text-neutral-400 text-xs rounded">{tech}</li>
      ))}
    </ul>
  </div>
  <div class="flex flex-row gap-4 pt-4 mt-auto">
    <a href={githubUrl} class="text-xs text-neutral-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer">Github ↗</a>
    {liveUrl && (
      <a href={liveUrl} class="text-xs text-green-500 hover:text-green-400 transition-colors" target="_blank" rel="noopener noreferrer">Ver el proyecto ↗</a>
    )}
  </div>
</section>
